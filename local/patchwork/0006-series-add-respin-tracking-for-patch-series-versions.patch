@@ -858,6 +863,15 @@ class Series(FilenameMixin, models.Model):
         related_query_name='dependent',
     )
 
+    # respin tracking
+    previous_series = models.ForeignKey(
+        'self',
+        null=True,
+        blank=True,
+        on_delete=models.SET_NULL,
+        related_name='next_series',
+    )
