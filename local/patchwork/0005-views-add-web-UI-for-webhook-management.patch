diff --git a/patchwork/templates/patchwork/webhook-create.html b/patchwork/templates/patchwork/webhook-create.html
new file mode 100644
index 000000000000..e3196dfcd14c
--- /dev/null
+++ b/patchwork/templates/patchwork/webhook-create.html
@@ -0,0 +1,35 @@
+{% extends "base.html" %}
+
+{% block title %}Add webhook - {{ project.name }}{% endblock %}
+
+{% block body %}
+<h1>Add webhook for {{ project.name }}</h1>
+
+<form method="POST">
+  {% csrf_token %}
+  <table class="horizontal">
+    <tr>
+      <th><label for="id_url">URL</label></th>
+      <td><input type="url" name="url" id="id_url" required class="form-control"></td>
+    </tr>
+    <tr>
+      <th><label for="id_secret">Secret</label></th>
+      <td><input type="password" name="secret" id="id_secret" class="form-control"></td>
+    </tr>
+    <tr>
+      <th><label for="id_events">Events</label></th>
+      <td>
+        <input type="text" name="events" id="id_events" value="*" class="form-control">
+        <p class="help-block">
+          Comma-separated list of event categories, or <code>*</code> for all.
+          Available: {% for cat, label in event_categories %}
+            <code>{{ cat }}</code>{% if not forloop.last %}, {% endif %}
+          {% endfor %}
+        </p>
+      </td>
+    </tr>
+  </table>
+  <button type="submit" class="btn btn-primary">Create</button>
+  <a href="{% url 'webhook-list' project_id=project.linkname %}" class="btn btn-default">Cancel</a>
+</form>
+{% endblock %}
