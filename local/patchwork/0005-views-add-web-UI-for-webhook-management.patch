diff --git a/patchwork/views/webhook.py b/patchwork/views/webhook.py
new file mode 100644
index 000000000000..5142a1c06718
--- /dev/null
+++ b/patchwork/views/webhook.py
@@ -0,0 +1,117 @@
+# Patchwork - automated patch tracking system
+# Copyright (C) 2026 Robin Jarry <robin@jarry.cc>
+#
+# SPDX-License-Identifier: GPL-2.0-or-later
+
+from django.contrib.auth.decorators import login_required
+from django.http import HttpResponseForbidden
+from django.http import HttpResponseRedirect
+from django.shortcuts import get_object_or_404
+from django.shortcuts import render
+from django.urls import reverse
+
+from patchwork.models import Event
+from patchwork.models import Project
+from patchwork.models import Webhook
+
+
+def _check_maintainer(request, project):
+    if not project.is_editable(request.user):
+        return HttpResponseForbidden('You are not a maintainer of this project')
+    return None
+
+
+@login_required
+def webhook_list(request, project_id):
+    project = get_object_or_404(Project, linkname=project_id)
+    denied = _check_maintainer(request, project)
+    if denied:
+        return denied
+
+    webhooks = Webhook.objects.filter(project=project)
+    context = {
+        'project': project,
+        'webhooks': webhooks,
+    }
+    return render(request, 'patchwork/webhooks.html', context)
+
+
+@login_required
+def webhook_create(request, project_id):
+    project = get_object_or_404(Project, linkname=project_id)
+    denied = _check_maintainer(request, project)
+    if denied:
+        return denied
+
+    if request.method == 'POST':
+        url = request.POST.get('url', '').strip()
+        secret = request.POST.get('secret', '').strip()
+        events = request.POST.get('events', '*').strip()
+        if url:
+            Webhook.objects.create(
+                project=project,
+                url=url,
+                secret=secret,
+                events=events,
+                creator=request.user,
+            )
+            return HttpResponseRedirect(
+                reverse('webhook-list', kwargs={'project_id': project_id})
+            )
+
+    context = {
+        'project': project,
+        'event_categories': Event.CATEGORY_CHOICES,
+    }
+    return render(request, 'patchwork/webhook-create.html', context)
+
+
+@login_required
+def webhook_update(request, project_id, webhook_id):
+    project = get_object_or_404(Project, linkname=project_id)
+    denied = _check_maintainer(request, project)
+    if denied:
+        return denied
+
+    webhook = get_object_or_404(Webhook, pk=webhook_id, project=project)
+
+    if request.method == 'POST':
+        webhook.url = request.POST.get('url', webhook.url).strip()
+        secret = request.POST.get('secret', '').strip()
+        if secret:
+            webhook.secret = secret
+        webhook.events = request.POST.get('events', webhook.events).strip()
+        webhook.active = 'active' in request.POST
+        webhook.save()
+        return HttpResponseRedirect(
+            reverse('webhook-list', kwargs={'project_id': project_id})
+        )
+
+    context = {
+        'project': project,
+        'webhook': webhook,
+        'event_categories': Event.CATEGORY_CHOICES,
+    }
+    return render(request, 'patchwork/webhook-update.html', context)
+
+
+@login_required
+def webhook_delete(request, project_id, webhook_id):
+    project = get_object_or_404(Project, linkname=project_id)
+    denied = _check_maintainer(request, project)
+    if denied:
+        return denied
+
+    webhook = get_object_or_404(Webhook, pk=webhook_id, project=project)
+
+    if request.method == 'POST':
+        webhook.delete()
+        return HttpResponseRedirect(
+            reverse('webhook-list', kwargs={'project_id': project_id})
+        )
+
+    context = {
+        'project': project,
+        'webhook': webhook,
+    }
+    return render(request, 'patchwork/webhook-delete.html', context)
