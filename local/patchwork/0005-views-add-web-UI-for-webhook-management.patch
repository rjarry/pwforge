--- /dev/null
+++ b/patchwork/templates/patchwork/webhook-update.html
@@ -0,0 +1,41 @@
+{% extends "base.html" %}
+
+{% block title %}Edit webhook - {{ project.name }}{% endblock %}
+
+{% block body %}
+<h1>Edit webhook for {{ project.name }}</h1>
+
+<form method="POST">
+  {% csrf_token %}
+  <table class="horizontal">
+    <tr>
+      <th><label for="id_url">URL</label></th>
+      <td><input type="url" name="url" id="id_url" value="{{ webhook.url }}" required class="form-control"></td>
+    </tr>
+    <tr>
+      <th><label for="id_secret">Secret</label></th>
+      <td>
+        <input type="password" name="secret" id="id_secret" class="form-control" placeholder="(unchanged)">
+      </td>
+    </tr>
+    <tr>
+      <th><label for="id_events">Events</label></th>
+      <td>
+        <input type="text" name="events" id="id_events" value="{{ webhook.events }}" class="form-control">
+        <p class="help-block">
+          Comma-separated list of event categories, or <code>*</code> for all.
+          Available: {% for cat, label in event_categories %}
+            <code>{{ cat }}</code>{% if not forloop.last %}, {% endif %}
+          {% endfor %}
+        </p>
+      </td>
+    </tr>
+    <tr>
+      <th><label for="id_active">Active</label></th>
+      <td><input type="checkbox" name="active" id="id_active" {% if webhook.active %}checked{% endif %}></td>
+    </tr>
+  </table>
+  <button type="submit" class="btn btn-primary">Save</button>
+  <a href="{% url 'webhook-list' project_id=project.linkname %}" class="btn btn-default">Cancel</a>
+</form>
+{% endblock %}
diff --git a/patchwork/templates/patchwork/webhooks.html b/patchwork/templates/patchwork/webhooks.html
new file mode 100644
index 000000000000..7d5fbd69706d
--- /dev/null
+++ b/patchwork/templates/patchwork/webhooks.html
@@ -0,0 +1,42 @@
+{% extends "base.html" %}
+
+{% block title %}Webhooks - {{ project.name }}{% endblock %}
+
+{% block body %}
+<h1>Webhooks for {{ project.name }}</h1>
+
+<p>
+  <a class="btn btn-default" href="{% url 'webhook-create' project_id=project.linkname %}">
+    Add webhook
+  </a>
+</p>
+
+{% if webhooks %}
+<table class="table">
+  <thead>
+    <tr>
+      <th>URL</th>
+      <th>Events</th>
+      <th>Active</th>
+      <th>Actions</th>
+    </tr>
+  </thead>
+  <tbody>
+{% for webhook in webhooks %}
+    <tr>
+      <td>{{ webhook.url }}</td>
+      <td>{{ webhook.events }}</td>
+      <td>{{ webhook.active|yesno:"Yes,No" }}</td>
+      <td>
+        <a href="{% url 'webhook-update' project_id=project.linkname webhook_id=webhook.id %}">Edit</a>
+        |
+        <a href="{% url 'webhook-delete' project_id=project.linkname webhook_id=webhook.id %}">Delete</a>
+      </td>
+    </tr>
+{% endfor %}
+  </tbody>
+</table>
+{% else %}
+<p>No webhooks configured.</p>
+{% endif %}
+{% endblock %}
